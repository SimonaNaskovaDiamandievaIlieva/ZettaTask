<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Automation Suite">

    <listeners>
        <listener class-name="testComponents.Listeners"/>
    </listeners>

    <test name="Regression Tests">
        <classes>
            <class name="uiTest.BookingTest"/>
        </classes>
    </test>

</suite>

